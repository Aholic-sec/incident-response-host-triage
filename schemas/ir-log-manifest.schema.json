{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/ir-log-manifest.schema.json",
  "title": "Incident Response Host Triage Log Manifest",
  "type": "object",
  "required": [
    "schema",
    "script_name",
    "script_version",
    "os_type",
    "hostname",
    "collected_at_utc",
    "output_directory",
    "privilege",
    "read_only",
    "network_upload_performed",
    "files"
  ],
  "properties": {
    "schema": {
      "const": "ir-log-manifest/v1"
    },
    "script_name": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "script_version": {
      "type": "string"
    },
    "collector_mode": {
      "type": "string"
    },
    "os_type": {
      "type": "string",
      "enum": ["windows", "linux"]
    },
    "hostname": {
      "type": "string"
    },
    "collected_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "collection_started_utc": {
      "type": "string"
    },
    "collection_finished_utc": {
      "type": "string"
    },
    "collection_profile": {
      "type": "string",
      "enum": ["quick", "standard", "deep", "legacy-standard"]
    },
    "output_directory": {
      "type": "string"
    },
    "privilege": {
      "type": "string",
      "enum": ["administrator", "root", "standard-user", "unknown"]
    },
    "collector_user": {
      "type": "string"
    },
    "read_only": {
      "type": "boolean",
      "const": true
    },
    "network_upload_performed": {
      "type": "boolean",
      "const": false
    },
    "sensitive_data_warning": {
      "type": "boolean"
    },
    "coverage": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["complete", "partial", "missing", "not_applicable"]
      }
    },
    "critical_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "command", "exit_code", "status"],
        "properties": {
          "file": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "exit_code": {},
          "status": {
            "type": "string",
            "enum": ["ok", "failed", "missing_tool", "timeout", "permission_denied"]
          },
          "started_utc": {
            "type": "string"
          },
          "finished_utc": {
            "type": "string"
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": true
      }
    },
    "command_failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "size", "sha256"],
        "properties": {
          "path": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
